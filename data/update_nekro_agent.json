{
  "version": "1.0",
  "steps": [
    {
      "type": "pull",
      "image": "kromiose/nekro-agent:latest",
      "label": "拉取最新 Nekro Agent 镜像",
      "step": 1
    },
    {
      "type": "compose_down",
      "services": ["nekro_agent"],
      "label": "停止 Nekro Agent 容器",
      "step": 2
    },
    {
      "type": "compose_up",
      "services": ["nekro_agent"],
      "label": "启动 Nekro Agent 容器",
      "step": 3
    },
    {
      "type": "notify",
      "message": "Nekro Agent 更新完成，服务已重启。",
      "step": 4
    }
  ]
}
