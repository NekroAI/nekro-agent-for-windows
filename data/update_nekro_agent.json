{
  "version": "1.1",
  "steps": [
    {
      "step": 1,
      "type": "notify",
      "label": "更新开始通知",
      "message": "正在更新 Nekro Agent，请稍候..."
    },
    {
      "step": 2,
      "type": "shell",
      "label": "创建数据目录备份",
      "command": "cp -r /root/nekro_agent_data /root/nekro_agent_data_backup"
    },
    {
      "step": 3,
      "type": "pull",
      "label": "拉取最新 Nekro Agent 镜像",
      "image": "kromiose/nekro-agent:latest"
    },
    {
      "step": 4,
      "type": "compose_up",
      "label": "重启 Nekro Agent 容器",
      "services": ["nekro_agent"]
    },
    {
      "step": 5,
      "type": "notify",
      "label": "更新完成通知",
      "message": "Nekro Agent 更新完成，服务已重启。"
    }
  ]
}
